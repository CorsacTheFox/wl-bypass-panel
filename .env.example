# Whitelist-Bypass Instance Manager — environment overrides.
# Copy to .env and edit. The systemd unit loads this via EnvironmentFile.

# ---- Server bind ----
WB_HOST=127.0.0.1
WB_PORT=8000

# ---- Bootstrap admin (created only on FIRST run, while no admin exists) ----
WB_ADMIN_USERNAME=admin
WB_ADMIN_PASSWORD=change-this-to-a-strong-password

# ---- Storage ----
WB_DATA_DIR=/opt/whitelist-manager/data
WB_BINARIES_DIR=/opt/whitelist-manager/binaries
WB_DATABASE_PATH=/opt/whitelist-manager/data/app.db

# ---- Policy ----
WB_DEFAULT_MAX_CONCURRENT=3
WB_DEFAULT_TIMEOUT_SECONDS=3600
WB_KILL_GRACE_SECONDS=5
WB_SESSION_TTL=43200
